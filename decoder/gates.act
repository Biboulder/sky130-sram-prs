import std;

namespace decoder {

    export namespace gates {

        export template <pint N>
        defproc nand (bool? in[N]; bool! out)
        {
            prs {
                (&i:N:  in[i]) -> out-
                (|i:N: ~in[i]) -> out+
            }
        }

        export defproc inv (bool? in; bool! out)
        {
            prs {
                in -> out-
                ~in -> out+
            }
        }
    }
}

